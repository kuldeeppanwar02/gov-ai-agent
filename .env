# ── AWS Credentials ────────────────────────────────
# Apne AWS keys yahan daalo (jo doosre project mein hain wahi kaam karenge)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── S3 ─────────────────────────────────────────────
S3_BUCKET_NAME=gov-ai-agent-seema-910445327304

# ── Amazon Bedrock Models ──────────────────────────
# (ye automatically use hote hain, change mat karo)
# BEDROCK_NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
# BEDROCK_NOVA_ACT_MODEL_ID=amazon.nova-act-v1:0

# ── Nova Act ───────────────────────────────────────
# OPTIONAL — sirf tab chahiye jab AWS keys kaam na karein
# Nova Act API key: https://nova-act.amazon.com/
NOVA_ACT_API_KEY=

# ── OpenSearch (optional) ──────────────────────────
OPENSEARCH_HOST=
OPENSEARCH_REGION=us-east-1

# ── CORS ───────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
